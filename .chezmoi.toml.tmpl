{{- $profiles := list "minimal" "server" "workstation" -}}
{{- $profile := promptStringOnce . "profile" "Machine profile (minimal / server / workstation)" "workstation" -}}
{{- if not (has $profile $profiles) -}}
{{-   writeToStdout (printf "Invalid profile %q; expected one of: minimal, server, workstation\n" $profile) -}}
{{-   exit 1 -}}
{{- end -}}

{{- /* Prefer elevated=false unless passwordless root/sudo is available now.
     Group membership alone is not enough — that would still prompt for a password. */ -}}
{{- $defaultElevated := "false" -}}
{{- if eq (output "id" "-u" | trim) "0" -}}
{{-   $defaultElevated = "true" -}}
{{- else -}}
{{-   if eq ((output "sh" "-c" "command -v sudo >/dev/null && sudo -n true >/dev/null 2>&1 && echo yes || echo no") | trim) "yes" -}}
{{-     $defaultElevated = "true" -}}
{{-   end -}}
{{- end -}}

{{- $elevatedRaw := promptStringOnce . "elevated" "Install system packages with sudo/apt and set login shell? (true / false)" $defaultElevated -}}
{{- $elevatedRaw = trim (lower $elevatedRaw) -}}
{{- if and (ne $elevatedRaw "true") (ne $elevatedRaw "false") (ne $elevatedRaw "yes") (ne $elevatedRaw "no") (ne $elevatedRaw "y") (ne $elevatedRaw "n") -}}
{{-   writeToStdout (printf "Invalid elevated value %q; expected true or false\n" $elevatedRaw) -}}
{{-   exit 1 -}}
{{- end -}}
{{- $elevated := or (eq $elevatedRaw "true") (eq $elevatedRaw "yes") (eq $elevatedRaw "y") -}}

[data]
    profile = {{ $profile | quote }}
    elevated = {{ $elevated }}

[diff]
    exclude = ["scripts"]

[status]
    exclude = ["scripts"]
