#!/usr/bin/env bash
set -euo pipefail

{{/* elevated from chezmoi data; default true for pre-migration configs */}}
{{- $elevated := true -}}
{{- if hasKey . "elevated" -}}
{{- $elevated = .elevated -}}
{{- end }}

can_elevate() {
    if [[ "${EUID:-$(id -u)}" -eq 0 ]]; then
        return 0
    fi
    if ! command -v sudo >/dev/null 2>&1; then
        return 1
    fi
    if sudo -n true >/dev/null 2>&1; then
        return 0
    fi
    id -nG 2>/dev/null | tr ' ' '\n' | grep -qxE 'sudo|wheel|admin'
}

# Triggers (change these so chezmoi re-runs this script):
# mise-run-installer-v1
# elevated={{ $elevated }} profile={{ .profile }}
# {{ include "dot_config/mise/config.toml.tmpl" | sha256sum }}
#
# Do not skip the installer just because mise is already on PATH — that would
# make bumping the trigger above silently ineffective.

ensure_mise() {
    # Keep installer chatter off stdout so callers can capture the binary path.
    curl -fsSL https://mise.run | sh >&2

    if [[ -x "$HOME/.local/bin/mise" ]]; then
        printf '%s\n' "$HOME/.local/bin/mise"
    elif command -v mise >/dev/null 2>&1; then
        command -v mise
    else
        printf 'mise installation failed\n' >&2
        return 1
    fi
}

userspace_cli_tools=(
    eza@latest
    starship@latest
    zoxide@latest
    bat@latest
    fd@latest
    ripgrep@latest
    fzf@latest
    jq@latest
    direnv@latest
)

{{- /* Userspace needs mise for CLIs; workstation uses it for runtimes.
     elevated=true normally skips mise (apt provides CLIs), but if sudo is
     unavailable we still install mise + shell CLIs into the user prefix. */}}
{{- if and $elevated (ne .profile "workstation") }}

if can_elevate; then
    exit 0
fi

printf 'elevated=true but no usable sudo; installing shell CLIs via mise\n'

mise_bin="$(ensure_mise)"

# config.toml has no userspace tools when elevated=true — install explicitly.
"$mise_bin" install "${userspace_cli_tools[@]}"

printf 'Shell CLIs installed via mise into your user prefix\n'
printf 'Ensure ~/.local/bin is on PATH (dot_zshenv adds it).\n'

{{- else }}

mise_bin="$(ensure_mise)"

if [[ -f "$HOME/.config/mise/config.toml" ]]; then
    "$mise_bin" install
fi

{{- if not $elevated }}
printf 'elevated=false: shell CLIs installed via mise into your user prefix\n'
printf 'Ensure ~/.local/bin is on PATH (dot_zshenv adds it).\n'
{{- end }}
{{- end }}
