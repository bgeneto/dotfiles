#!/usr/bin/env bash
set -euo pipefail

# Userspace-first bootstrap. Sudo/apt is optional and never required.
# Never prompt for a sudo password.

mkdir -p "$HOME/.local/bin" \
    "$HOME/.config/zsh/conf.d" \
    "$HOME/.cache/zsh" \
    "$HOME/.local/state/zsh"

{{- /* Default elevated=true when key is absent (pre-migration configs). */ -}}
{{- $elevated := true -}}
{{- if hasKey . "elevated" -}}
{{- $elevated = .elevated -}}
{{- end }}

can_elevate() {
    if [[ "${EUID:-$(id -u)}" -eq 0 ]]; then
        return 0
    fi
    command -v sudo >/dev/null 2>&1 || return 1
    sudo -n true >/dev/null 2>&1
}

# Must already be on the host (not installed by this userspace script).
require_host_tools() {
    local missing=0

    if ! command -v zsh >/dev/null 2>&1; then
        cat >&2 <<'EOF'
zsh is required but was not found on PATH.

Install zsh with your OS package manager (or ask an administrator), then re-run.
EOF
        missing=1
    fi

    if ! command -v curl >/dev/null 2>&1 && ! command -v wget >/dev/null 2>&1; then
        printf 'curl or wget is required but was not found on PATH\n' >&2
        missing=1
    fi

    if ! command -v git >/dev/null 2>&1; then
        printf 'git is required but was not found on PATH\n' >&2
        missing=1
    fi

    return "$missing"
}

link_debian_alternatives() {
    if command -v batcat >/dev/null 2>&1 &&
       ! command -v bat >/dev/null 2>&1; then
        ln -sfn "$(command -v batcat)" "$HOME/.local/bin/bat"
    fi

    if command -v fdfind >/dev/null 2>&1 &&
       ! command -v fd >/dev/null 2>&1; then
        ln -sfn "$(command -v fdfind)" "$HOME/.local/bin/fd"
    fi
}

# Optional convenience: if the user opted in AND passwordless sudo works,
# install packages system-wide. This is never required for bootstrap.
{{- if $elevated }}
if [[ "$(uname -s)" == "Linux" ]] && [[ -f /etc/debian_version ]] && can_elevate; then
    if [[ "${EUID:-$(id -u)}" -eq 0 ]]; then
        SUDO=()
    else
        SUDO=(sudo)
    fi

    packages=(
        zsh
        git
        curl
        wget
        ca-certificates
        unzip
        xz-utils
        fontconfig
        fzf
        starship
        eza
        zoxide
        bat
        fd-find
        ripgrep
        direnv
        tree
        jq
        lsof
        pigz
    )

{{- if or (eq .profile "server") (eq .profile "workstation") }}
    packages+=(
        tmux
        htop
        rsync
        ncdu
    )
{{- end }}

    printf 'Passwordless sudo available: installing packages with apt\n'
    "${SUDO[@]}" apt-get update
    DEBIAN_FRONTEND=noninteractive \
        "${SUDO[@]}" apt-get install -y "${packages[@]}"
fi
{{- end }}

require_host_tools
link_debian_alternatives
