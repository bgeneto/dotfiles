# mise tools — managed by chezmoi (templated from elevated/profile).
# After changing this file: chezmoi apply && mise install
#
# Shell CLIs (eza, starship, …) are NOT listed here on purpose.
# Bootstrap prefers host binaries; gaps go into conf.d/shell-clis.toml via
# `mise use --path` (chezmoi-safe) and are also symlinked into ~/.local/bin.

{{- $elevated := true -}}
{{- if hasKey . "elevated" -}}
{{- $elevated = .elevated -}}
{{- end }}

[settings]
experimental = false

[tools]
{{- if eq .profile "workstation" }}
# Language runtimes / CLIs for workstation profiles.
# Prefer `mise use` in a project (writes mise.toml) or uncomment globals here:
#
#   mise use node@24 python@3.13
#   mise use --global go@1.24 rust@stable java@temurin-21
#
# node = "24"
# python = "3.13"
# go = "1.24"
{{- end }}
